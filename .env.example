# VerifID — déploiement sur l'infra iwm partagée. Copier en .env et compléter.

# Base partagée (mot de passe = celui du Postgres iwm, voir .env de la stack iwm)
IWM_DB_USER=iwm
IWM_DB_PASSWORD=change-me-meme-mdp-que-iwm
VERIFID_DB_NAME=verifid

# ClientApplication "verifid-backend" enregistrée dans iwm (serviceCode KYC)
KERNEL_CLIENT_ID=verifid-backend
KERNEL_API_KEY=change-me-secret-clientapplication-kyc

# Secrets applicatifs VerifID
# openssl rand -hex 32
JWT_SECRET=change-me-jwt-secret
# clé AES-256 (32 octets) : openssl rand -hex 16  (donne 32 hex chars) ou base64
ENCRYPTION_SECRET_KEY=change-me-aes-256-key

# Intégrations externes (laisser vide pour l'instant)
GEMINI_API_KEY=
BREVO_API_KEY=

# Port public exposé sur la VM
VERIFID_PUBLIC_PORT=8083

# Traefik : base d'hôte public (= <IP_VM>.nip.io)
PUBLIC_HOST=CHANGE_ME.nip.io
